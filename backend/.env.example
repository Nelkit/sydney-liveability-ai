# ------------------------------
# Core (recommended defaults)
# ------------------------------
LLM_PROVIDER=openrouter
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_API_KEY=your-openrouter-key-here

# ------------------------------
# App settings
# ------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
CHROMADB_PATH=./data/chromadb
FRONTEND_URL=http://localhost:3000
SYNTHESIS_DEBUG_MODE=off  # supported: off | gis | all

# ------------------------------
# Optional providers (only if used)
# ------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ------------------------------
# Optional overrides (advanced)
# ------------------------------
# 1) Per-agent model override (if omitted, all agents use LLM_MODEL)
# LLM_AGENT_MODELS_JSON={"router":"nvidia/nemotron-3-super-120b-a12b:free","gis":"nvidia/nemotron-3-super-120b-a12b:free","crime":"nvidia/nemotron-3-super-120b-a12b:free","sentiment":"nvidia/nemotron-3-super-120b-a12b:free","comparator":"nvidia/nemotron-3-super-120b-a12b:free","synthesiser":"nvidia/nemotron-3-super-120b-a12b:free"}

# 2) Example production switch (OpenRouter + Claude)
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-3.5-sonnet

# 3) Alternative production switch (native Anthropic)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022

# 4) Alternative production switch (OpenAI)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your-openai-api-key-here
